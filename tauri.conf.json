{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "src/ui",
    "distDir": "src/ui"
  },
  "package": {
    "productName": "ScreenCopilot",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "open": true },
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://127.0.0.1:8765/**"]
      },
      "dialog": { "open": true }
    },
    "bundle": {
      "active": true,
      "icon": [],
      "identifier": "ai.titan.screencopilot"
    },
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:8765 https://fonts.googleapis.com https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com"
    },
    "windows": [
      {
        "title": "ScreenCopilot",
        "width": 480,
        "height": 760,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ]
  }
}
